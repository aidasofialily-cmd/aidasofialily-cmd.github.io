# AIDASOFIALILY_CMD INDUSTRIAL CONFIG
# TARGET: github.com/aidasofialily-cmd/aidasofialily-cmd.github.io

# Route scoped packages to GitHub Packages Registry
@aidasofialily-cmd:registry=https://npm.pkg.github.com

# Always use specific versions (matches your strict technical focus)
save-exact=true

# Ensure consistent lockfiles across Windows 11 and OS X 10.10
package-lock=true

# Progress bar off to maximize terminal performance on legacy systems
progress=false
